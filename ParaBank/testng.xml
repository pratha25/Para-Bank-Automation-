<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="ParaBank Automation Suite" verbose="1" parallel="false">
<listeners>
    <listener class-name="listeners.TestListener"/>
</listeners>
    <parameter name="browser" value="chrome"/>

    

    <test name="Registration Tests">
        <classes>
            <class name="testcases.RegistrationTest"/>
        </classes>
    </test>
    <test name="Login Tests">
        <classes>
            <class name="testcases.LoginTest"/>
        </classes>
    </test>
 <test name="Open Account Tests">
        <classes>
            <class name="testcases.OpenAccountTest"/>
        </classes>
    </test>
    <test name="Account Overview Tests">
        <classes>
            <class name="testcases.AccountOverviewTest"/>
        </classes>
    </test>

    <test name="Transfer Funds Tests">
        <classes>
            <class name="testcases.TransferFundsTest"/>
        </classes>
    </test>

    <test name="Bill Pay Tests">
        <classes>
            <class name="testcases.BillPayTest"/>
        </classes>
    </test>

</suite>